{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "fanzines-app-2",
  "compatibility_date": "2026-06-15",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1,
    },
  },
  "routes": [
    {
      "pattern": "beta.fanzines.app",
      "custom_domain": true,
    },
  ],
  "preview_urls": true,
}
